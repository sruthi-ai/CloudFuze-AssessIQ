# ─── PRODUCTION SETUP ────────────────────────────────────────────────────────
# Copy this file to .env in the same directory as docker-compose.prod.yml:
#   cp .env.docker.example .env
# Then fill in real values. This file is .gitignored — never commit .env.
#
# On the server: /opt/neutaraassessment/.env
# docker-compose.prod.yml reads .env automatically (no --env-file flag needed).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Strong password for the PostgreSQL assessiq user.
# IMPORTANT: If you change this after first deploy, run:
#   docker compose -f docker-compose.prod.yml exec db psql -U assessiq -d assessiq \
#     -c "ALTER USER assessiq WITH PASSWORD 'your-new-password';"
DB_PASSWORD=change_me_strong_password

# ── Redis (rate-limiter persistent store) ──────────────────────────────────────
# Provisioned automatically by docker-compose.prod.yml — no value needed here,
# the backend connects to it via the REDIS_URL env var set directly in that file.

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://neutaraassessment.cftools.live

# ── OpenAI (REQUIRED for the IELTS/TOEFL AI features) ──────────────────────────
# Powers: AI question generation, Writing rubric grading, Listening TTS audio
# generation, and Speaking transcription + rubric grading. Without this, those
# features are disabled (essay grading silently falls back to a word-count heuristic).
# Use a PRODUCTION key — never reuse a key that has been shared in chat/logs.
OPENAI_API_KEY=

# ── Email (optional — needed for candidate invites) ───────────────────────────
# Leave blank if using per-tenant SMTP configured in Settings UI
RESEND_API_KEY=
FROM_EMAIL=noreply@neutaraassessment.cftools.live

# ── Code Execution (optional) ─────────────────────────────────────────────────
JUDGE0_API_KEY=
JUDGE0_URL=https://judge0-ce.p.rapidapi.com

# ── Azure Graph API (optional — for sending email via Office 365 / Outlook) ──
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Copy this file to .env.docker and fill in real values before deploying.
# docker-compose.prod.yml reads these automatically when you pass --env-file .env.docker

# ── Database ──────────────────────────────────────────────────────────────────
# Strong password for the PostgreSQL assessiq user
DB_PASSWORD=change_me_strong_password

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://neutaraassessment.cftools.live

# ── Email (optional — needed for candidate invites) ───────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@neutaraassessment.cftools.live

# ── Code Execution (optional) ─────────────────────────────────────────────────
JUDGE0_API_KEY=
JUDGE0_URL=https://judge0-ce.p.rapidapi.com

# ── Azure SSO (optional) ──────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

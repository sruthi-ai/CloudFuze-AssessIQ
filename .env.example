JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
RESEND_API_KEY="re_xxxxxxxxxxxx"

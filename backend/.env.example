DATABASE_URL="postgresql://postgres:password@localhost:5432/assessiq"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
HOST="0.0.0.0"
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
RESEND_API_KEY="re_xxxxxxxxxxxx"
FROM_EMAIL="noreply@assessiq.com"

# OpenAI API — required for AI question generation
# Get your key at platform.openai.com
OPENAI_API_KEY="sk-proj-..."

# Microsoft Graph / Outlook 365 email (optional — needed when any tenant uses "Microsoft Graph" provider)
# Register an Azure App: portal.azure.com → App registrations → New → API permissions → Microsoft Graph → Mail.Send (Application)
# Grant admin consent, then create a Client secret under Certificates & secrets
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
